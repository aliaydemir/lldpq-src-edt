#!/usr/bin/env bash
# LLDPq Network Monitoring - Main execution script
# Copyright (c) 2024 LLDPq Project - Licensed under MIT License

# Load the installed path fail-closed. Explicit LLDPQ_DIR remains supported for
# isolated tests/source-tree runs, but a partial production upgrade must never
# fall back to a different $HOME/lldpq tree.
lldpq_fatal() {
    printf 'lldpq: ERROR: %s\n' "$*" >&2
    exit 1
}
LLDPQ_CONFIG_HELPER="${LLDPQ_CONFIG_HELPER:-/usr/local/bin/lldpq-config}"
if [[ -x "$LLDPQ_CONFIG_HELPER" ]]; then
    if ! LLDPQ_CONFIG_ASSIGNMENTS=$("$LLDPQ_CONFIG_HELPER" --require-config \
        --require-key LLDPQ_DIR --require-key LLDPQ_USER \
        --require-key WEB_ROOT 2>/dev/null); then
        lldpq_fatal "required runtime configuration is missing or unreadable"
    fi
    eval "$LLDPQ_CONFIG_ASSIGNMENTS" || \
        lldpq_fatal "runtime configuration could not be applied"
    unset LLDPQ_CONFIG_ASSIGNMENTS
elif [[ -z "${LLDPQ_DIR:-}" ]]; then
    lldpq_fatal "required config helper is missing: $LLDPQ_CONFIG_HELPER"
fi
[[ -n "${LLDPQ_DIR:-}" ]] || lldpq_fatal "LLDPQ_DIR is empty"
[[ -n "${WEB_ROOT:-}" ]] || lldpq_fatal "WEB_ROOT is empty"
LLDPQ_USER="${LLDPQ_USER:-$(id -un)}"

# Parse flags: lldpq - (verbose, including per-analyzer timing),
# lldpq -s (skip optical).
QUIET=true
MONITOR_FLAGS=()
for arg in "$@"; do
    case "$arg" in
        -) QUIET=false ;;
        -s) MONITOR_FLAGS+=("-s") ;;
    esac
done

# Stage skip toggles arrive from lldpq.conf via the config helper. Anything
# but true/1/yes/on means false — collection stays fail-safe on.
normalize_bool() {
    case "$(printf '%s' "$1" | tr '[:upper:]' '[:lower:]')" in
        true|1|yes|y|on) printf 'true' ;;
        *) printf 'false' ;;
    esac
}
SKIP_ASSETS="$(normalize_bool "${SKIP_ASSETS:-false}")"
SKIP_LLDP="$(normalize_bool "${SKIP_LLDP:-false}")"
SKIP_MONITOR="$(normalize_bool "${SKIP_MONITOR:-false}")"
SKIP_FABRIC_SCAN="$(normalize_bool "${SKIP_FABRIC_SCAN:-false}")"
SKIP_ALERTS="$(normalize_bool "${SKIP_ALERTS:-false}")"

# Skip notices are informational and verbose-only: the scheduled cron line has
# no output redirect, so unconditional stdout would become recurring cron mail.
log_notice() {
    [[ "$QUIET" == "true" ]] || echo "$1"
}

cd "$LLDPQ_DIR" || exit 1

# One lock covers asset discovery, LLDP validation, monitoring, and report
# publication. monitor.sh uses the same lock when invoked directly.
LOCK_FILE="${LLDPQ_MONITOR_LOCK_FILE:-/tmp/lldpq-monitor.lock}"
LOCK_WAIT_SECONDS="${LLDPQ_MONITOR_LOCK_WAIT_SECONDS:-0}"
case "$LOCK_WAIT_SECONDS" in
    ''|*[!0-9]*) LOCK_WAIT_SECONDS=0 ;;
esac
if (( LOCK_WAIT_SECONDS > 600 )); then
    LOCK_WAIT_SECONDS=600
fi
LOCK_REQUESTED_AT=$(date +%s)
if ! command -v flock >/dev/null 2>&1; then
    echo "Error: flock is required for safe monitoring" >&2
    exit 1
fi
exec 9>"$LOCK_FILE" || exit 1
if (( LOCK_WAIT_SECONDS > 0 )); then
    flock -w "$LOCK_WAIT_SECONDS" 9
    lock_status=$?
else
    flock -n 9
    lock_status=$?
fi
if (( lock_status != 0 )); then
    echo "Monitoring is already running; this invocation was skipped." >&2
    exit 75
fi
# A scheduled run may have waited behind an older full pipeline rather than a
# cache scan. If that pipeline published after this request began, do not run a
# duplicate generation back-to-back. Waiting behind Fabric Scan leaves the
# manifest older than this request and proceeds normally.
CURRENT_MANIFEST="$LLDPQ_DIR/monitor-results/.lldpq-current.json"
if (( LOCK_WAIT_SECONDS > 0 )) && [[ -f "$CURRENT_MANIFEST" ]]; then
    CURRENT_MANIFEST_MTIME=$(stat -c '%Y' "$CURRENT_MANIFEST" 2>/dev/null || echo 0)
    if [[ "$CURRENT_MANIFEST_MTIME" =~ ^[0-9]+$ ]] && \
       (( CURRENT_MANIFEST_MTIME >= LOCK_REQUESTED_AT )); then
        echo "A newer full monitoring generation completed while this scheduled run waited; skipping duplicate." >&2
        exit 75
    fi
fi
export LLDPQ_MONITOR_LOCK_HELD=1

# Bind assets, LLDP and monitor outputs to one pipeline identity. monitor.sh
# records exact source fingerprints; alert summaries reject mixed-run inputs.
# When assets or LLDP collection is skipped by configuration this run cannot
# claim a complete pipeline: its sources predate the run and the manifest
# mtime check would (correctly) fail. Withhold the identity so monitor.sh
# publishes under its fallback id with pipeline_complete=false instead.
if [[ "$SKIP_ASSETS" == "true" || "$SKIP_LLDP" == "true" ]]; then
    unset LLDPQ_PIPELINE_ID LLDPQ_PIPELINE_STARTED_AT
else
    export LLDPQ_PIPELINE_ID="$(date -u '+%Y%m%dT%H%M%SZ')-$$-$RANDOM"
    export LLDPQ_PIPELINE_STARTED_AT="$(date +%s)"
fi

# The monitor owns the final current manifest and clears this marker only after
# a complete web publication.  The wrapper starts the same state contract
# before assets/LLDP collection so an upstream failure cannot leave the prior
# generation looking current.
REPORT_DIR="$LLDPQ_DIR/monitor-results"
STALE_MARKER="$REPORT_DIR/.lldpq-stale"
PIPELINE_REPORT_STATE=idle

publish_web_pipeline_marker() {
    local source_marker=$1
    local web_dir="$WEB_ROOT/monitor-results"
    local web_marker="$web_dir/.lldpq-stale"
    local web_temporary=""

    [[ -d "$web_dir" ]] || return 0

    # A legacy Docker layout may expose the source marker directly. Keep the
    # single inode but still enforce the web-reader contract explicitly.
    if [[ -e "$web_marker" || -L "$web_marker" ]] && \
       [[ "$source_marker" -ef "$web_marker" ]]; then
        sudo chown "$LLDPQ_USER:www-data" "$source_marker" 2>/dev/null && \
            sudo chmod 0640 "$source_marker" 2>/dev/null
        return $?
    fi

    # Build the public marker beside its destination, set final metadata while
    # it is still private, then expose it with one same-filesystem rename. This
    # prevents nginx from observing partial content or a root-only sudo-cp file.
    web_temporary=$(sudo mktemp "$web_dir/.lldpq-stale.tmp.XXXXXXXX" 2>/dev/null) || \
        return 1
    if ! sudo cp -- "$source_marker" "$web_temporary" 2>/dev/null || \
       ! sudo chown "$LLDPQ_USER:www-data" "$web_temporary" 2>/dev/null || \
       ! sudo chmod 0640 "$web_temporary" 2>/dev/null || \
       ! sudo mv -fT -- "$web_temporary" "$web_marker" 2>/dev/null; then
        sudo rm -f -- "$web_temporary" 2>/dev/null || true
        return 1
    fi
    return 0
}

write_pipeline_report_marker() {
    local marker_status=$1 reason=$2 timestamp temporary
    mkdir -p "$REPORT_DIR" || return 1
    timestamp=$(date -Is) || return 1
    temporary=$(mktemp "$REPORT_DIR/.lldpq-stale.tmp.XXXXXXXX") || return 1
    if ! {
        printf 'status=%s\n' "$marker_status"
        printf 'timestamp=%s\n' "$timestamp"
        printf 'reason=%s\n' "$reason"
        printf 'pipeline_id=%s\n' "${LLDPQ_PIPELINE_ID:-}"
    } > "$temporary" || ! chmod 0644 "$temporary" || \
       ! mv -f "$temporary" "$STALE_MARKER"; then
        rm -f "$temporary"
        return 1
    fi

    publish_web_pipeline_marker "$STALE_MARKER"
}

mark_pipeline_reports_stale() {
    local reason=$1 timestamp
    PIPELINE_REPORT_STATE=stale
    write_pipeline_report_marker stale "$reason" || return 1
    timestamp=$(date -Is) || timestamp=unknown
    printf '%s %s\n' "$timestamp" "$reason" >> "$LLDPQ_DIR/monitor-failures.log" || true
    return 0
}

pipeline_exit_guard() {
    local status=$?
    trap - EXIT
    if [[ "$PIPELINE_REPORT_STATE" == "collecting" ]]; then
        mark_pipeline_reports_stale \
            "pipeline exited unexpectedly with status $status" || true
    fi
    exit "$status"
}
trap pipeline_exit_guard EXIT

run_command() {
    if [[ "$QUIET" == "true" ]]; then
        "$@" >/dev/null 2>&1
    else
        "$@"
    fi
}

wait_until_not_running() {
    script_name="$1"
    while pgrep -f "$script_name" >/dev/null; do
        sleep 10
    done
}

# Mark the complete generation as collecting before its first mutable input is
# gathered.  monitor.sh replaces this marker with its own in-progress state and
# clears it only after a successful, atomic report publication.  With the
# monitor stage skipped no report generation happens in this run: the marker
# stays untouched so the exit guard cannot stale last-known-good reports.
if [[ "$SKIP_MONITOR" != "true" ]]; then
    PIPELINE_REPORT_STATE=collecting
    if ! write_pipeline_report_marker collecting pipeline_collection_in_progress; then
        mark_pipeline_reports_stale "could not mark pipeline reports as in-progress" || true
        echo "Could not mark monitoring reports as in-progress." >&2
        exit 1
    fi
fi

# Run asset discovery and LLDP checks. A pre-monitor collection failure only
# invalidates the published reports when this run would have replaced them;
# with SKIP_MONITOR the reports belong to an older generation whose validity
# is unaffected, so the stage fails without staling them.
if [[ "$SKIP_ASSETS" == "true" ]]; then
    log_notice "Asset discovery skipped by configuration (SKIP_ASSETS=true)."
else
    wait_until_not_running "assets.sh"
    if ! run_command ./assets.sh; then
        if [[ "$SKIP_MONITOR" != "true" ]]; then
            mark_pipeline_reports_stale "asset discovery failed before monitoring" || true
        fi
        echo "Asset discovery failed; monitoring was not published." >&2
        exit 1
    fi
fi
# Total-fabric loss must be alertable even when LLDP/monitor analyzers cannot
# produce a new aggregate bundle. This path is stateful and silent for the
# normal/partial case; it emits only total-outage and recovery transitions.
# It is delivered through the alert machinery, so SKIP_ALERTS silences it too.
if [[ "$SKIP_ALERTS" == "true" ]]; then
    log_notice "Fabric availability pre-check skipped by configuration (SKIP_ALERTS=true)."
else
    run_command python3 ./check_alerts.py --assets-only || \
        echo "⚠️  Fabric availability pre-check failed (non-critical)" >&2
fi
if [[ "$SKIP_LLDP" == "true" ]]; then
    # The raw-inputs invariant below validates this run's collection; with the
    # stage skipped there is nothing to validate and leftovers from an older
    # failed run must not fail a run that never touched LLDP.
    log_notice "LLDP collection skipped by configuration (SKIP_LLDP=true)."
else
    wait_until_not_running "check-lldp.sh"
    if ! run_command ./check-lldp.sh; then
        if [[ "$SKIP_MONITOR" != "true" ]]; then
            mark_pipeline_reports_stale "LLDP collection failed before monitoring" || true
        fi
        echo "LLDP collection failed; monitoring was not published." >&2
        exit 1
    fi
    # lldp-validate.py intentionally leaves raw inputs in place on a topology
    # generation failure. check-lldp.sh predates strict exit propagation, so use
    # that invariant to prevent the rest of the run from looking successful.
    if compgen -G "lldp-results/*_lldp_result.ini" >/dev/null; then
        if [[ "$SKIP_MONITOR" != "true" ]]; then
            mark_pipeline_reports_stale \
                "LLDP validation/topology generation did not complete" || true
        fi
        echo "LLDP validation/topology generation did not complete; raw inputs were preserved." >&2
        exit 1
    fi
fi
if [[ "$SKIP_MONITOR" == "true" ]]; then
    log_notice "Monitoring analysis skipped by configuration (SKIP_MONITOR=true)."
else
    run_command ./monitor.sh "${MONITOR_FLAGS[@]}"
    status=$?
    if [[ $status -ne 0 ]]; then
        if grep -q '^status=stale$' "$STALE_MARKER" 2>/dev/null; then
            PIPELINE_REPORT_STATE=stale
        else
            mark_pipeline_reports_stale \
                "monitoring analysis failed with status $status" || true
        fi
        echo "Monitoring analysis failed; last-known-good reports were preserved." >&2
        exit "$status"
    fi
    if [[ -e "$STALE_MARKER" ]]; then
        mark_pipeline_reports_stale \
            "monitor returned success without clearing the report state marker" || true
        echo "Monitoring returned success but report state is not current." >&2
        exit 1
    fi
    PIPELINE_REPORT_STATE=current
fi

# Fabric table scan for search. A partial scan must not suppress availability
# alerts from the already-published monitor/assets snapshot. A configured skip
# is a success: it must not block the AI launch nor fail the pipeline.
if [[ "$SKIP_FABRIC_SCAN" == "true" ]]; then
    fabric_status=0
    log_notice "Fabric scan skipped by configuration (SKIP_FABRIC_SCAN=true)."
else
    wait_until_not_running "fabric-scan.sh"
    run_command ./fabric-scan.sh
    fabric_status=$?
    if [[ $fabric_status -ne 0 ]]; then
        echo "Fabric scan failed." >&2
    fi
fi

# Check for network alerts (only if monitoring data exists)
if [[ "$SKIP_ALERTS" == "true" ]]; then
    log_notice "Alert checks skipped by configuration (SKIP_ALERTS=true)."
elif [[ -d "monitor-results" ]] && [[ -f "notifications.yaml" ]]; then
    run_command python3 ./check_alerts.py || echo "⚠️  Alert check failed (non-critical)"
fi

# A trusted autonomous AI report must be based on the generation that just
# finished, not on a fixed clock minute that can land inside a long collector.
# The analyzer applies its own one-hour throttle and runs detached so it neither
# extends this command nor inherits descriptor 9 and keeps the pipeline locked.
AI_ANALYZER="${LLDPQ_AI_ANALYZER:-/usr/local/bin/lldpq-ai-analyze}"
if [[ $fabric_status -eq 0 && -x "$AI_ANALYZER" ]]; then
    nohup "$AI_ANALYZER" --if-due >/dev/null 2>&1 9>&- &
fi

exit "$fabric_status"
