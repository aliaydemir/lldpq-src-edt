#!/usr/bin/env bash
# LLDPq Trigger - Self-loop daemon for web interface triggers
# Add to crontab: * * * * * /usr/local/bin/lldpq-trigger
# Copyright (c) 2024 LLDPq Project - Licensed under MIT License

# Load config.  This daemon controls every web-triggered refresh, so continuing
# with $HOME/lldpq after a partial upgrade makes the UI appear to accept work
# that can never run.  Treat the installed helper and config as required.
trigger_fatal() {
    printf 'lldpq-trigger: ERROR: %s\n' "$*" >&2
    exit 1
}
LLDPQ_CONFIG_HELPER="${LLDPQ_CONFIG_HELPER:-/usr/local/bin/lldpq-config}"
[[ -x "$LLDPQ_CONFIG_HELPER" ]] || \
    trigger_fatal "required config helper is missing: $LLDPQ_CONFIG_HELPER"
if ! LLDPQ_CONFIG_ASSIGNMENTS=$("$LLDPQ_CONFIG_HELPER" --require-config \
    --require-key LLDPQ_DIR --require-key LLDPQ_USER --require-key WEB_ROOT \
    2>/dev/null); then
    trigger_fatal "required runtime configuration is missing or unreadable"
fi
eval "$LLDPQ_CONFIG_ASSIGNMENTS" || \
    trigger_fatal "runtime configuration could not be applied"
unset LLDPQ_CONFIG_ASSIGNMENTS
LLDPQ_DIR="${LLDPQ_DIR:-$HOME/lldpq}"
MONITOR_TRIGGER_FILE="${LLDPQ_MONITOR_TRIGGER_FILE:-/tmp/.monitor_web_trigger}"
CONFIGS_TRIGGER_FILE="/tmp/.configs_web_trigger"
TRANSCEIVER_TRIGGER_FILE="/tmp/.transceiver_web_trigger"
DAEMON_PID_FILE="${LLDPQ_TRIGGER_DAEMON_PID_FILE:-/tmp/lldp_trigger_daemon.pid}"
DAEMON_LOCK_FILE="${LLDPQ_TRIGGER_DAEMON_LOCK_FILE:-/tmp/lldpq-trigger-daemon.lock}"
CONFIGS_LOCK_FILE="/tmp/configs_running.lock"
MONITOR_LOCK_FILE="${LLDPQ_MONITOR_LOCK_FILE:-/tmp/lldpq-monitor.lock}"
LLDP_JOB_DIR="${LLDPQ_LLDP_JOB_DIR:-/var/lib/lldpq/lldp-jobs}"
ASSETS_JOB_DIR="${LLDPQ_ASSETS_JOB_DIR:-/var/lib/lldpq/assets-jobs}"

# Failed config collections remain pending, but use a bounded exponential
# backoff instead of launching a full-fabric ping/SSH sweep every three seconds.
CONFIGS_RETRY_BASE_SECONDS="${LLDPQ_CONFIG_RETRY_BASE_SECONDS:-30}"
CONFIGS_RETRY_MAX_SECONDS="${LLDPQ_CONFIG_RETRY_MAX_SECONDS:-300}"
TRIGGER_RETRY_BASE_SECONDS="${LLDPQ_TRIGGER_RETRY_BASE_SECONDS:-30}"
TRIGGER_RETRY_MAX_SECONDS="${LLDPQ_TRIGGER_RETRY_MAX_SECONDS:-300}"
LLDP_JOB_STATUS_TTL_SECONDS="${LLDPQ_LLDP_JOB_STATUS_TTL_SECONDS:-86400}"
ASSETS_JOB_STATUS_TTL_SECONDS="${LLDPQ_ASSETS_JOB_STATUS_TTL_SECONDS:-$LLDP_JOB_STATUS_TTL_SECONDS}"
case "$CONFIGS_RETRY_BASE_SECONDS" in
    ''|*[!0-9]*|0) trigger_fatal "invalid LLDPQ_CONFIG_RETRY_BASE_SECONDS" ;;
esac
case "$CONFIGS_RETRY_MAX_SECONDS" in
    ''|*[!0-9]*|0) trigger_fatal "invalid LLDPQ_CONFIG_RETRY_MAX_SECONDS" ;;
esac
if (( CONFIGS_RETRY_MAX_SECONDS < CONFIGS_RETRY_BASE_SECONDS )); then
    CONFIGS_RETRY_MAX_SECONDS="$CONFIGS_RETRY_BASE_SECONDS"
fi
case "$TRIGGER_RETRY_BASE_SECONDS" in
    ''|*[!0-9]*|0) trigger_fatal "invalid LLDPQ_TRIGGER_RETRY_BASE_SECONDS" ;;
esac
case "$TRIGGER_RETRY_MAX_SECONDS" in
    ''|*[!0-9]*|0) trigger_fatal "invalid LLDPQ_TRIGGER_RETRY_MAX_SECONDS" ;;
esac
if (( TRIGGER_RETRY_MAX_SECONDS < TRIGGER_RETRY_BASE_SECONDS )); then
    TRIGGER_RETRY_MAX_SECONDS="$TRIGGER_RETRY_BASE_SECONDS"
fi
case "$LLDP_JOB_STATUS_TTL_SECONDS" in
    ''|*[!0-9]*|0) trigger_fatal "invalid LLDPQ_LLDP_JOB_STATUS_TTL_SECONDS" ;;
esac
case "$ASSETS_JOB_STATUS_TTL_SECONDS" in
    ''|*[!0-9]*|0) trigger_fatal "invalid LLDPQ_ASSETS_JOB_STATUS_TTL_SECONDS" ;;
esac

next_retry_delay() {
    local current="$1" maximum="$2" doubled
    doubled=$((current * 2))
    if (( doubled > maximum || doubled < current )); then
        printf '%s\n' "$maximum"
    else
        printf '%s\n' "$doubled"
    fi
}

# Trigger identities are opaque, atomic tokens.  Seconds-only mtimes collapse
# two clicks made in the same second; storing the producer token losslessly
# also lets a click during a long-running refresh remain pending for the next
# loop iteration.
write_trigger_timestamp() {
    local destination="$1" value="$2" temporary
    temporary="${destination}.tmp.$$"
    if ! printf '%s\n' "$value" > "$temporary" ||
       ! mv -f "$temporary" "$destination"; then
        rm -f "$temporary"
        return 1
    fi
}

read_trigger_timestamp() {
    local source_file="$1" value=0
    if [[ -f "$source_file" ]]; then
        value=$(cat "$source_file" 2>/dev/null) || value=0
    fi
    [[ "$value" =~ ^[0-9]+([.:-][0-9]+)*$ ]] || value=0
    printf '%s\n' "$value"
}

monitor_scope_valid() {
    case "${1-}" in
        all|bgp|evpn-mh|duplicate|flap|optical|ber|pfc-ecn|hardware|logs) return 0 ;;
        *) return 1 ;;
    esac
}

# Decode the optional numeric scope suffix emitted by trigger-monitor.sh.
# Legacy opaque tokens have no 7246 sentinel and remain full-run requests.
read_monitor_trigger_request() {
    local source_file=$1 token="" extra="" scope_code
    MONITOR_REQUEST_TOKEN=0
    MONITOR_REQUEST_SCOPE=all
    [[ -f "$source_file" ]] || return 1
    IFS=' ' read -r token extra < "$source_file" || return 1
    [[ -z "$extra" ]] || return 1
    [[ "$token" =~ ^[0-9]+([.:-][0-9]+)*$ ]] || return 1

    if [[ "$token" =~ ^[0-9]+\.[0-9]+\.[0-9]+\.7246\.([0-9]+)$ ]]; then
        scope_code=${BASH_REMATCH[1]}
        case "$scope_code" in
            0) MONITOR_REQUEST_SCOPE=all ;;
            1) MONITOR_REQUEST_SCOPE=bgp ;;
            2) MONITOR_REQUEST_SCOPE=duplicate ;;
            3) MONITOR_REQUEST_SCOPE=flap ;;
            4) MONITOR_REQUEST_SCOPE=optical ;;
            5) MONITOR_REQUEST_SCOPE=ber ;;
            6) MONITOR_REQUEST_SCOPE=pfc-ecn ;;
            7) MONITOR_REQUEST_SCOPE=hardware ;;
            8) MONITOR_REQUEST_SCOPE=logs ;;
            9) MONITOR_REQUEST_SCOPE=evpn-mh ;;
            *) return 1 ;;
        esac
    fi
    MONITOR_REQUEST_TOKEN=$token
    return 0
}

lldp_job_valid_token() {
    [[ "${1-}" =~ ^[a-f0-9]{32}$ ]]
}

lldp_job_field() {
    local file=$1 key=$2
    awk -F= -v wanted="$key" '$1 == wanted { sub(/^[^=]*=/, ""); print; exit }' \
        "$file" 2>/dev/null
}

lldp_job_number() {
    [[ "${1-}" =~ ^[0-9]+$ ]] && printf '%s\n' "$1" || printf '0\n'
}

ensure_lldp_job_dir() {
    mkdir -p -m 2770 "$LLDP_JOB_DIR" 2>/dev/null || return 1
    chmod 2770 "$LLDP_JOB_DIR" 2>/dev/null || true
    [[ -d "$LLDP_JOB_DIR" && -r "$LLDP_JOB_DIR" && -w "$LLDP_JOB_DIR" ]]
}

ensure_assets_job_dir() {
    mkdir -p -m 2770 "$ASSETS_JOB_DIR" 2>/dev/null || return 1
    chmod 2770 "$ASSETS_JOB_DIR" 2>/dev/null || true
    [[ -d "$ASSETS_JOB_DIR" && -r "$ASSETS_JOB_DIR" && -w "$ASSETS_JOB_DIR" ]]
}

# Atomically publish one complete token-specific lifecycle snapshot.  Readers
# therefore see either the previous state or the next state, never a partially
# rewritten file while the daemon is transitioning queued/running/failure.
write_lldp_job_status() {
    local token=$1 state=$2 created_at=$3 started_at=$4 completed_at=$5
    local attempt=$6 exit_code=$7 next_retry_at=$8 retry_scheduled=$9
    local reason=${10-} worker_pid=0 temporary

    lldp_job_valid_token "$token" || return 1
    case "$state" in queued|running|success|failure) ;; *) return 1 ;; esac
    created_at=$(lldp_job_number "$created_at")
    started_at=$(lldp_job_number "$started_at")
    completed_at=$(lldp_job_number "$completed_at")
    attempt=$(lldp_job_number "$attempt")
    next_retry_at=$(lldp_job_number "$next_retry_at")
    [[ "$exit_code" =~ ^[0-9]+$ ]] || exit_code=""
    [[ "$retry_scheduled" == "true" ]] || retry_scheduled=false
    [[ "$state" == "running" ]] && worker_pid=$$
    reason=${reason//$'\n'/ }
    reason=${reason//$'\r'/ }

    ensure_lldp_job_dir || return 1
    temporary=$(mktemp "$LLDP_JOB_DIR/.${token}.status.XXXXXXXX") || return 1
    if ! {
        printf 'token=%s\n' "$token"
        printf 'state=%s\n' "$state"
        printf 'created_at=%s\n' "$created_at"
        printf 'updated_at=%s\n' "$(date +%s)"
        printf 'started_at=%s\n' "$started_at"
        printf 'completed_at=%s\n' "$completed_at"
        printf 'attempt=%s\n' "$attempt"
        printf 'exit_code=%s\n' "$exit_code"
        printf 'next_retry_at=%s\n' "$next_retry_at"
        printf 'retry_scheduled=%s\n' "$retry_scheduled"
        printf 'worker_pid=%s\n' "$worker_pid"
        printf 'reason=%s\n' "$reason"
    } > "$temporary" || ! chmod 0660 "$temporary" || \
       ! mv -f "$temporary" "$LLDP_JOB_DIR/$token.status"; then
        rm -f "$temporary" 2>/dev/null || true
        return 1
    fi
}

lldp_retry_delay() {
    local attempt=$1 delay=$TRIGGER_RETRY_BASE_SECONDS
    local maximum=$TRIGGER_RETRY_MAX_SECONDS steps
    attempt=$(lldp_job_number "$attempt")
    steps=$((attempt > 0 ? attempt - 1 : 0))
    while (( steps > 0 && delay < maximum )); do
        delay=$(next_retry_delay "$delay" "$maximum")
        steps=$((steps - 1))
    done
    printf '%s\n' "$delay"
}

cleanup_lldp_job_statuses() {
    local status_file token updated_at now
    ensure_lldp_job_dir || return 1
    now=$(date +%s)
    for status_file in "$LLDP_JOB_DIR"/*.status; do
        [[ -f "$status_file" ]] || continue
        token=${status_file##*/}
        token=${token%.status}
        lldp_job_valid_token "$token" || continue
        # Presence of the request is authoritative for queued/running/retrying
        # work.  Never age out an active request, even if its status is old.
        [[ ! -f "$LLDP_JOB_DIR/$token.request" ]] || continue
        updated_at=$(lldp_job_number "$(lldp_job_field "$status_file" updated_at)")
        if (( updated_at > 0 && now - updated_at >= LLDP_JOB_STATUS_TTL_SECONDS )); then
            rm -f "$status_file"
        fi
    done
}

# Assets refreshes use the same lifecycle contract as standalone LLDP jobs,
# but a separate directory prevents either worker from consuming the other
# request type.  The field format deliberately stays identical for the UI.
write_assets_job_status() {
    local token=$1 state=$2 created_at=$3 started_at=$4 completed_at=$5
    local attempt=$6 exit_code=$7 next_retry_at=$8 retry_scheduled=$9
    local reason=${10-} worker_pid=0 temporary

    lldp_job_valid_token "$token" || return 1
    case "$state" in queued|running|success|failure) ;; *) return 1 ;; esac
    created_at=$(lldp_job_number "$created_at")
    started_at=$(lldp_job_number "$started_at")
    completed_at=$(lldp_job_number "$completed_at")
    attempt=$(lldp_job_number "$attempt")
    next_retry_at=$(lldp_job_number "$next_retry_at")
    [[ "$exit_code" =~ ^[0-9]+$ ]] || exit_code=""
    [[ "$retry_scheduled" == "true" ]] || retry_scheduled=false
    [[ "$state" == "running" ]] && worker_pid=$$
    reason=${reason//$'\n'/ }
    reason=${reason//$'\r'/ }

    ensure_assets_job_dir || return 1
    temporary=$(mktemp "$ASSETS_JOB_DIR/.${token}.status.XXXXXXXX") || return 1
    if ! {
        printf 'token=%s\n' "$token"
        printf 'state=%s\n' "$state"
        printf 'created_at=%s\n' "$created_at"
        printf 'updated_at=%s\n' "$(date +%s)"
        printf 'started_at=%s\n' "$started_at"
        printf 'completed_at=%s\n' "$completed_at"
        printf 'attempt=%s\n' "$attempt"
        printf 'exit_code=%s\n' "$exit_code"
        printf 'next_retry_at=%s\n' "$next_retry_at"
        printf 'retry_scheduled=%s\n' "$retry_scheduled"
        printf 'worker_pid=%s\n' "$worker_pid"
        printf 'reason=%s\n' "$reason"
    } > "$temporary" || ! chmod 0660 "$temporary" || \
       ! mv -f "$temporary" "$ASSETS_JOB_DIR/$token.status"; then
        rm -f "$temporary" 2>/dev/null || true
        return 1
    fi
}

cleanup_assets_job_statuses() {
    local status_file token updated_at now
    ensure_assets_job_dir || return 1
    now=$(date +%s)
    for status_file in "$ASSETS_JOB_DIR"/*.status; do
        [[ -f "$status_file" ]] || continue
        token=${status_file##*/}
        token=${token%.status}
        lldp_job_valid_token "$token" || continue
        [[ ! -f "$ASSETS_JOB_DIR/$token.request" ]] || continue
        updated_at=$(lldp_job_number "$(lldp_job_field "$status_file" updated_at)")
        if (( updated_at > 0 && now - updated_at >= ASSETS_JOB_STATUS_TTL_SECONDS )); then
            rm -f "$status_file"
        fi
    done
}

# The full web analysis gathers assets and LLDP before monitor.sh starts.  Mark
# that upstream phase too, otherwise an early failure leaves the previous
# .lldpq-current.json looking like the result of the new request.
TRIGGER_REPORT_DIR="$LLDPQ_DIR/monitor-results"
TRIGGER_STALE_MARKER="$TRIGGER_REPORT_DIR/.lldpq-stale"

publish_trigger_web_marker() {
    local source_marker=$1
    local web_dir="$WEB_ROOT/monitor-results"
    local web_marker="$web_dir/.lldpq-stale"
    local web_temporary=""

    [[ -d "$web_dir" ]] || return 0

    if [[ -e "$web_marker" || -L "$web_marker" ]] && \
       [[ "$source_marker" -ef "$web_marker" ]]; then
        sudo chown "$LLDPQ_USER:www-data" "$source_marker" 2>/dev/null && \
            sudo chmod 0640 "$source_marker" 2>/dev/null
        return $?
    fi

    web_temporary=$(sudo mktemp "$web_dir/.lldpq-stale.tmp.XXXXXXXX" 2>/dev/null) || \
        return 1
    if ! sudo cp -- "$source_marker" "$web_temporary" 2>/dev/null || \
       ! sudo chown "$LLDPQ_USER:www-data" "$web_temporary" 2>/dev/null || \
       ! sudo chmod 0640 "$web_temporary" 2>/dev/null || \
       ! sudo mv -fT -- "$web_temporary" "$web_marker" 2>/dev/null; then
        sudo rm -f -- "$web_temporary" 2>/dev/null || true
        return 1
    fi
    return 0
}

write_trigger_report_marker() {
    local marker_status=$1 reason=$2 timestamp temporary
    mkdir -p "$TRIGGER_REPORT_DIR" || return 1
    timestamp=$(date -Is) || return 1
    temporary=$(mktemp "$TRIGGER_REPORT_DIR/.lldpq-stale.tmp.XXXXXXXX") || return 1
    if ! {
        printf 'status=%s\n' "$marker_status"
        printf 'timestamp=%s\n' "$timestamp"
        printf 'reason=%s\n' "$reason"
        printf 'pipeline_id=%s\n' "${LLDPQ_PIPELINE_ID:-}"
    } > "$temporary" || ! chmod 0644 "$temporary" || \
       ! mv -f "$temporary" "$TRIGGER_STALE_MARKER"; then
        rm -f "$temporary"
        return 1
    fi

    publish_trigger_web_marker "$TRIGGER_STALE_MARKER"
}

mark_trigger_reports_stale() {
    local reason=$1 timestamp
    write_trigger_report_marker stale "$reason" || return 1
    timestamp=$(date -Is) || timestamp=unknown
    printf '%s %s\n' "$timestamp" "$reason" >> "$LLDPQ_DIR/monitor-failures.log" || true
}

write_scoped_trigger_state() {
    local scope=$1 state=$2 reason=$3 pipeline_id=$4
    local state_dir marker temporary timestamp web_dir web_marker web_temporary
    monitor_scope_valid "$scope" || return 1
    [[ "$scope" != "all" ]] || return 1
    case "$state" in collecting|current|stale) ;; *) return 1 ;; esac
    [[ "$pipeline_id" =~ ^[A-Za-z0-9_.:-]{1,128}$ ]] || return 1
    reason=${reason//$'\n'/ }
    reason=${reason//$'\r'/ }
    timestamp=$(date -Is) || return 1
    state_dir="$TRIGGER_REPORT_DIR/.analysis-state"
    marker="$state_dir/${scope}.status"
    mkdir -p "$state_dir" || return 1
    temporary=$(mktemp "$state_dir/.${scope}.status.tmp.XXXXXXXX") || return 1
    if ! {
        printf 'status=%s\n' "$state"
        printf 'timestamp=%s\n' "$timestamp"
        printf 'reason=%s\n' "$reason"
        printf 'scope=%s\n' "$scope"
        printf 'pipeline_id=%s\n' "$pipeline_id"
    } > "$temporary" || ! chmod 0644 "$temporary" ||
       ! mv -f "$temporary" "$marker"; then
        rm -f "$temporary" 2>/dev/null || true
        return 1
    fi

    web_dir="$WEB_ROOT/monitor-results/.analysis-state"
    [[ -d "$WEB_ROOT/monitor-results" ]] || return 0
    sudo mkdir -p "$web_dir" 2>/dev/null || return 1
    web_marker="$web_dir/${scope}.status"
    if [[ -e "$web_marker" || -L "$web_marker" ]] &&
       [[ "$marker" -ef "$web_marker" ]]; then
        sudo chown "$LLDPQ_USER:www-data" "$marker" 2>/dev/null &&
            sudo chmod 0640 "$marker" 2>/dev/null
        return $?
    fi
    web_temporary=$(sudo mktemp \
        "$web_dir/.${scope}.status.tmp.XXXXXXXX" 2>/dev/null) || return 1
    if ! sudo cp -- "$marker" "$web_temporary" 2>/dev/null ||
       ! sudo chown "$LLDPQ_USER:www-data" "$web_temporary" 2>/dev/null ||
       ! sudo chmod 0640 "$web_temporary" 2>/dev/null ||
       ! sudo mv -fT -- "$web_temporary" "$web_marker" 2>/dev/null; then
        sudo rm -f "$web_temporary" 2>/dev/null || true
        return 1
    fi
    return 0
}

if [[ "${LLDPQ_TRIGGER_LIB_ONLY:-false}" == "true" ]]; then
    return 0 2>/dev/null || exit 0
fi

ensure_lldp_job_dir || \
    trigger_fatal "LLDP job directory is missing or not writable: $LLDP_JOB_DIR"
ensure_assets_job_dir || \
    trigger_fatal "Assets job directory is missing or not writable: $ASSETS_JOB_DIR"

# Hold one kernel lock for the daemon's entire lifetime.  A PID
# check-then-write is not atomic and PID reuse can reject the real successor;
# the PID file below is therefore diagnostic only and is written after flock.
command -v flock >/dev/null 2>&1 || trigger_fatal "flock is required"
exec {DAEMON_LOCK_FD}>"$DAEMON_LOCK_FILE" || \
    trigger_fatal "could not open daemon lock: $DAEMON_LOCK_FILE"
if ! flock -n "$DAEMON_LOCK_FD"; then
    exit 0
fi
DAEMON_PID_TEMP="${DAEMON_PID_FILE}.tmp.$$"
if ! printf '%s\n' "$$" > "$DAEMON_PID_TEMP" || \
   ! mv -f "$DAEMON_PID_TEMP" "$DAEMON_PID_FILE"; then
    rm -f "$DAEMON_PID_TEMP" 2>/dev/null || true
    printf 'lldpq-trigger: WARNING: could not publish diagnostic PID file: %s\n' \
        "$DAEMON_PID_FILE" >&2
fi

# Cleanup function - only remove PID file if it belongs to us
cleanup() {
    if [ -f "$CONFIGS_LOCK_FILE" ] && [ "$(cat "$CONFIGS_LOCK_FILE" 2>/dev/null)" = "$$" ]; then
        rm -f "$CONFIGS_LOCK_FILE"
    fi
    if [ -f "$DAEMON_PID_FILE" ] && [ "$(cat "$DAEMON_PID_FILE" 2>/dev/null)" = "$$" ]; then
        rm -f "$DAEMON_PID_FILE"
    fi
    exit 0
}

# Set trap for cleanup on exit
trap cleanup SIGTERM SIGINT EXIT

# Wait function to prevent conflicts
wait_until_not_running() {
    local script_name="${1#./}"
    local pattern="(^|/|[[:space:]])${script_name}([[:space:]]|$)"
    while pgrep -f "$pattern" >/dev/null; do
        sleep 2
    done
}

run_under_monitor_lock() {
    (
        command -v flock >/dev/null 2>&1 || return 1
        exec 9>"$MONITOR_LOCK_FILE" || return 1
        flock -n 9 || return 75
        # check-lldp.sh and monitor.sh verify both this marker and inherited fd
        # 9 before trusting the caller.  Exporting only after flock succeeds
        # prevents either child from trying to acquire our own lock again.
        export LLDPQ_MONITOR_LOCK_HELD=1
        "$@"
    )
}

refresh_lldp() {
    cd "$LLDPQ_DIR" || return 1
    wait_until_not_running "./assets.sh"
    ./assets.sh >/dev/null 2>&1 || return 1
    wait_until_not_running "./check-lldp.sh"
    ./check-lldp.sh >/dev/null 2>&1
}

# Process the newest outstanding web request.  The pre-existing trigger was a
# single latest-value slot, so a newer click superseded an older pending click.
# Keep that workload behaviour, but explicitly close superseded tokens instead
# of silently losing them: every browser receives a matching terminal state.
process_lldp_jobs() {
    local request_file token request_token created_at latest_file="" latest_token=""
    local latest_created=0 status_file state started_at attempt
    local next_retry_at retry_scheduled now result delay old_attempt
    local -a request_snapshot=()

    ensure_lldp_job_dir || {
        printf 'lldpq-trigger: LLDP job directory is unavailable: %s\n' \
            "$LLDP_JOB_DIR" >&2
        return 1
    }

    # Freeze membership before selecting/superseding.  A CGI request published
    # after this point belongs to the next daemon iteration; without this array
    # snapshot a newer request could appear only in the second glob and be
    # incorrectly closed as older than the already-selected request.
    for request_file in "$LLDP_JOB_DIR"/*.request; do
        [[ -f "$request_file" ]] && request_snapshot+=("$request_file")
    done

    # Select by creation time, then mtime for clicks which landed in one second.
    for request_file in "${request_snapshot[@]}"; do
        token=${request_file##*/}
        token=${token%.request}
        lldp_job_valid_token "$token" || continue
        request_token=$(lldp_job_field "$request_file" token)
        [[ "$request_token" == "$token" ]] || continue
        created_at=$(lldp_job_number "$(lldp_job_field "$request_file" created_at)")
        if (( created_at > latest_created )) || \
           { (( created_at == latest_created )) && \
             { [[ -z "$latest_file" ]] || [[ "$request_file" -nt "$latest_file" ]]; }; }; then
            latest_file=$request_file
            latest_token=$token
            latest_created=$created_at
        fi
    done
    [[ -n "$latest_file" ]] || return 0

    # A rapid second click used to overwrite the first trigger.  Record that
    # supersession for the old opaque token so its poller cannot wait forever.
    for request_file in "${request_snapshot[@]}"; do
        [[ -f "$request_file" && "$request_file" != "$latest_file" ]] || continue
        token=${request_file##*/}
        token=${token%.request}
        lldp_job_valid_token "$token" || continue
        status_file="$LLDP_JOB_DIR/$token.status"
        created_at=$(lldp_job_number "$(lldp_job_field "$request_file" created_at)")
        started_at=$(lldp_job_number "$(lldp_job_field "$status_file" started_at)")
        attempt=$(lldp_job_number "$(lldp_job_field "$status_file" attempt)")
        now=$(date +%s)
        if write_lldp_job_status "$token" failure "$created_at" "$started_at" \
            "$now" "$attempt" 125 0 false \
            "Superseded by a newer LLDP request"; then
            rm -f "$request_file"
        fi
    done

    token=$latest_token
    request_file=$latest_file
    status_file="$LLDP_JOB_DIR/$token.status"
    created_at=$latest_created
    state=$(lldp_job_field "$status_file" state)
    started_at=$(lldp_job_number "$(lldp_job_field "$status_file" started_at)")
    attempt=$(lldp_job_number "$(lldp_job_field "$status_file" attempt)")
    next_retry_at=$(lldp_job_number "$(lldp_job_field "$status_file" next_retry_at)")
    retry_scheduled=$(lldp_job_field "$status_file" retry_scheduled)
    now=$(date +%s)

    # A running snapshot belongs to a previous daemon instance: the PID-file
    # guard means two healthy daemon loops cannot reach this branch together.
    # Re-queue it and let the monitor flock serialize against any surviving
    # child process from an abrupt daemon restart.
    if [[ "$state" == "running" ]]; then
        write_lldp_job_status "$token" queued "$created_at" "$started_at" 0 \
            "$attempt" "" 0 false "Recovered after LLDP worker restart" || return 1
        state=queued
        next_retry_at=0
    elif [[ "$state" == "success" ]]; then
        rm -f "$request_file"
        return 0
    elif [[ "$state" == "failure" && "$retry_scheduled" != "true" ]]; then
        rm -f "$request_file"
        return 0
    elif [[ "$state" != "queued" && "$state" != "failure" ]]; then
        write_lldp_job_status "$token" queued "$created_at" 0 0 0 "" 0 false \
            "Recovered request with missing job status" || return 1
        started_at=0
        attempt=0
        next_retry_at=0
    fi

    (( now >= next_retry_at )) || return 0

    old_attempt=$attempt
    attempt=$((attempt + 1))
    (( started_at > 0 )) || started_at=$now
    write_lldp_job_status "$token" running "$created_at" "$started_at" 0 \
        "$attempt" "" 0 false "LLDP collection is running" || return 1

    run_under_monitor_lock refresh_lldp
    result=$?
    now=$(date +%s)
    if (( result == 0 )); then
        if write_lldp_job_status "$token" success "$created_at" "$started_at" \
            "$now" "$attempt" 0 0 false "LLDP collection completed"; then
            rm -f "$request_file"
            return 0
        fi
        return 1
    fi

    if (( result == 75 )); then
        # Lock contention is not a collection failure and does not consume an
        # attempt.  Keep it visibly queued and retry on the normal daemon loop.
        next_retry_at=$((now + 3))
        write_lldp_job_status "$token" queued "$created_at" "$started_at" 0 \
            "$old_attempt" "" "$next_retry_at" false \
            "Waiting for another analysis to release the monitor lock" || return 1
        return 0
    fi

    # Actual assets/check-lldp failure remains retriable without a finite cap,
    # matching the daemon's established bounded exponential retry semantics.
    # The failure is nevertheless published immediately so the UI can surface
    # it and re-enable the button while continuing a low-frequency token poll.
    delay=$(lldp_retry_delay "$attempt")
    next_retry_at=$((now + delay))
    write_lldp_job_status "$token" failure "$created_at" "$started_at" 0 \
        "$attempt" "$result" "$next_retry_at" true \
        "LLDP refresh failed with status $result; automatic retry in ${delay}s" || return 1
    printf 'lldpq-trigger: LLDP refresh token %s failed; retrying in %ss\n' \
        "$token" "$delay" >&2
    return 0
}

refresh_assets() {
    cd "$LLDPQ_DIR" || return 1
    wait_until_not_running "./assets.sh"
    ./assets.sh >/dev/null 2>&1
}

process_assets_jobs() {
    local request_file token request_token created_at latest_file="" latest_token=""
    local latest_created=0 status_file state started_at attempt
    local next_retry_at retry_scheduled now result delay old_attempt
    local -a request_snapshot=()

    ensure_assets_job_dir || {
        printf 'lldpq-trigger: Assets job directory is unavailable: %s\n' \
            "$ASSETS_JOB_DIR" >&2
        return 1
    }

    # Freeze the request set before choosing the newest job.  A request which
    # arrives during this pass remains queued for the next daemon iteration.
    for request_file in "$ASSETS_JOB_DIR"/*.request; do
        [[ -f "$request_file" ]] && request_snapshot+=("$request_file")
    done

    for request_file in "${request_snapshot[@]}"; do
        token=${request_file##*/}
        token=${token%.request}
        lldp_job_valid_token "$token" || continue
        request_token=$(lldp_job_field "$request_file" token)
        [[ "$request_token" == "$token" ]] || continue
        created_at=$(lldp_job_number "$(lldp_job_field "$request_file" created_at)")
        if (( created_at > latest_created )) || \
           { (( created_at == latest_created )) && \
             { [[ -z "$latest_file" ]] || [[ "$request_file" -nt "$latest_file" ]]; }; }; then
            latest_file=$request_file
            latest_token=$token
            latest_created=$created_at
        fi
    done
    [[ -n "$latest_file" ]] || return 0

    # Preserve the former one-slot trigger semantics while terminating every
    # older token explicitly, so no browser poller can wait indefinitely.
    for request_file in "${request_snapshot[@]}"; do
        [[ -f "$request_file" && "$request_file" != "$latest_file" ]] || continue
        token=${request_file##*/}
        token=${token%.request}
        lldp_job_valid_token "$token" || continue
        status_file="$ASSETS_JOB_DIR/$token.status"
        created_at=$(lldp_job_number "$(lldp_job_field "$request_file" created_at)")
        started_at=$(lldp_job_number "$(lldp_job_field "$status_file" started_at)")
        attempt=$(lldp_job_number "$(lldp_job_field "$status_file" attempt)")
        now=$(date +%s)
        if write_assets_job_status "$token" failure "$created_at" "$started_at" \
            "$now" "$attempt" 125 0 false \
            "Superseded by a newer Assets request"; then
            rm -f "$request_file"
        fi
    done

    token=$latest_token
    request_file=$latest_file
    status_file="$ASSETS_JOB_DIR/$token.status"
    created_at=$latest_created
    state=$(lldp_job_field "$status_file" state)
    started_at=$(lldp_job_number "$(lldp_job_field "$status_file" started_at)")
    attempt=$(lldp_job_number "$(lldp_job_field "$status_file" attempt)")
    next_retry_at=$(lldp_job_number "$(lldp_job_field "$status_file" next_retry_at)")
    retry_scheduled=$(lldp_job_field "$status_file" retry_scheduled)
    now=$(date +%s)

    if [[ "$state" == "running" ]]; then
        write_assets_job_status "$token" queued "$created_at" "$started_at" 0 \
            "$attempt" "" 0 false "Recovered after Assets worker restart" || return 1
        state=queued
        next_retry_at=0
    elif [[ "$state" == "success" ]]; then
        rm -f "$request_file"
        return 0
    elif [[ "$state" == "failure" && "$retry_scheduled" != "true" ]]; then
        rm -f "$request_file"
        return 0
    elif [[ "$state" != "queued" && "$state" != "failure" ]]; then
        write_assets_job_status "$token" queued "$created_at" 0 0 0 "" 0 false \
            "Recovered request with missing Assets job status" || return 1
        started_at=0
        attempt=0
        next_retry_at=0
    fi

    (( now >= next_retry_at )) || return 0

    old_attempt=$attempt
    attempt=$((attempt + 1))
    (( started_at > 0 )) || started_at=$now
    write_assets_job_status "$token" running "$created_at" "$started_at" 0 \
        "$attempt" "" 0 false "Assets collection is running" || return 1

    run_under_monitor_lock refresh_assets
    result=$?
    now=$(date +%s)
    if (( result == 0 )); then
        if write_assets_job_status "$token" success "$created_at" "$started_at" \
            "$now" "$attempt" 0 0 false "Assets report published"; then
            rm -f "$request_file"
            return 0
        fi
        return 1
    fi

    if (( result == 75 )); then
        next_retry_at=$((now + 3))
        write_assets_job_status "$token" queued "$created_at" "$started_at" 0 \
            "$old_attempt" "" "$next_retry_at" false \
            "Waiting for another analysis to release the monitor lock" || return 1
        return 0
    fi

    delay=$(lldp_retry_delay "$attempt")
    next_retry_at=$((now + delay))
    write_assets_job_status "$token" failure "$created_at" "$started_at" 0 \
        "$attempt" "$result" "$next_retry_at" true \
        "Assets refresh failed with status $result; automatic retry in ${delay}s" || return 1
    printf 'lldpq-trigger: Assets refresh token %s failed; retrying in %ss\n' \
        "$token" "$delay" >&2
    return 0
}

refresh_monitor() (
    local requested_pipeline_id=${1-} requested_scope=${2:-all}
    local report_state=idle status scope_marker scope_reason

    trigger_monitor_exit_guard() {
        local exit_status=$?
        trap - EXIT
        if [[ "$report_state" == "collecting" ]]; then
            mark_trigger_reports_stale \
                "web analysis exited unexpectedly with status $exit_status" || true
        fi
        exit "$exit_status"
    }
    trap trigger_monitor_exit_guard EXIT

    cd "$LLDPQ_DIR" || return 1
    if [[ ! "$requested_pipeline_id" =~ ^[A-Za-z0-9_.:-]{1,128}$ ]]; then
        if [[ "$requested_scope" == "all" ]]; then
            mark_trigger_reports_stale "invalid web analysis request identity" || true
            report_state=stale
        fi
        return 1
    fi
    monitor_scope_valid "$requested_scope" || return 1
    export LLDPQ_PIPELINE_ID="$requested_pipeline_id"
    export LLDPQ_PIPELINE_STARTED_AT="$(date +%s)"

    if [[ "$requested_scope" != "all" ]]; then
        report_state=scoped
        LLDPQ_MONITOR_LOCK_HELD=1 ./monitor.sh --only "$requested_scope" \
            >/dev/null 2>&1
        status=$?
        if [[ $status -ne 0 ]]; then
            scope_marker="$TRIGGER_REPORT_DIR/.analysis-state/${requested_scope}.status"
            scope_reason="scoped analysis failed with status $status"
            if [[ "$(lldp_job_field "$scope_marker" pipeline_id)" == \
                      "$requested_pipeline_id" &&
                  "$(lldp_job_field "$scope_marker" status)" == "stale" ]]; then
                scope_reason=$(lldp_job_field "$scope_marker" reason)
                [[ -n "$scope_reason" ]] || \
                    scope_reason="scoped analysis failed with status $status"
            fi
            # Always republish the terminal state. monitor.sh deliberately
            # preserves its local stale marker if web publication fails.
            write_scoped_trigger_state "$requested_scope" stale \
                "$scope_reason" "$requested_pipeline_id" || true
            return "$status"
        fi

        scope_marker="$TRIGGER_REPORT_DIR/.analysis-state/${requested_scope}.status"
        if [[ "$(lldp_job_field "$scope_marker" status)" != "current" ||
              "$(lldp_job_field "$scope_marker" scope)" != "$requested_scope" ||
              "$(lldp_job_field "$scope_marker" pipeline_id)" != \
                  "$requested_pipeline_id" ]]; then
            printf 'lldpq-trigger: scoped monitor returned success without matching completion state: %s\n' \
                "$requested_scope" >&2
            write_scoped_trigger_state "$requested_scope" stale \
                "scoped analysis completed without matching report state" \
                "$requested_pipeline_id" || true
            return 1
        fi
        report_state=current
        return 0
    fi

    report_state=collecting
    if ! write_trigger_report_marker collecting web_analysis_collection_in_progress; then
        mark_trigger_reports_stale \
            "could not mark web analysis reports as in-progress" || true
        report_state=stale
        return 1
    fi
    wait_until_not_running "./assets.sh"
    if ! ./assets.sh >/dev/null 2>&1; then
        mark_trigger_reports_stale \
            "asset discovery failed before web analysis" || true
        report_state=stale
        return 1
    fi
    wait_until_not_running "./check-lldp.sh"
    if ! ./check-lldp.sh >/dev/null 2>&1; then
        mark_trigger_reports_stale \
            "LLDP collection failed before web analysis" || true
        report_state=stale
        return 1
    fi
    if compgen -G "lldp-results/*_lldp_result.ini" >/dev/null; then
        mark_trigger_reports_stale \
            "LLDP validation/topology generation did not complete" || true
        report_state=stale
        return 1
    fi
    LLDPQ_MONITOR_LOCK_HELD=1 ./monitor.sh >/dev/null 2>&1
    status=$?
    if [[ $status -ne 0 ]]; then
        if grep -q '^status=stale$' "$TRIGGER_STALE_MARKER" 2>/dev/null; then
            report_state=stale
        else
            mark_trigger_reports_stale \
                "web monitoring analysis failed with status $status" || true
            report_state=stale
        fi
        return "$status"
    fi
    if [[ -e "$TRIGGER_STALE_MARKER" ]]; then
        mark_trigger_reports_stale \
            "web monitor returned success without clearing the report state marker" || true
        report_state=stale
        return 1
    fi
    report_state=current
    return 0
)

refresh_configs() {
    cd "$LLDPQ_DIR" || return 1
    # The collector's full-run flock is authoritative. A concurrent cron or
    # manual run returns 75 here and remains pending for bounded retry.
    ./get-configs.sh >/dev/null 2>&1
}

refresh_transceiver() {
    cd "$LLDPQ_DIR" || return 1
    # On-demand transceiver firmware sweep. collect-transceiver-fw.sh holds its
    # own flock + minimum-interval and runs independently of the monitor lock,
    # so a long mlxlink pass never blocks the LLDP/monitor/assets/configs paths.
    ./collect-transceiver-fw.sh >/dev/null 2>&1
}

# Main daemon loop - check every 5 seconds
MONITOR_LAST_CHECK_FILE="${LLDPQ_MONITOR_LAST_CHECK_FILE:-$LLDPQ_DIR/.last_monitor_trigger_check}"
CONFIGS_LAST_CHECK_FILE="$LLDPQ_DIR/.last_configs_trigger_check"
TRANSCEIVER_LAST_CHECK_FILE="$LLDPQ_DIR/.last_transceiver_trigger_check"
MONITOR_PENDING_TRIGGER_TIME=0
MONITOR_PENDING_SCOPE=all
MONITOR_NEXT_RETRY_AT=0
MONITOR_RETRY_DELAY="$TRIGGER_RETRY_BASE_SECONDS"
CONFIGS_PENDING_TRIGGER_TIME=0
CONFIGS_NEXT_RETRY_AT=0
CONFIGS_RETRY_DELAY="$CONFIGS_RETRY_BASE_SECONDS"
LLDP_NEXT_STATUS_CLEANUP_AT=0

while true; do
    LLDP_NOW=$(date +%s)
    if (( LLDP_NOW >= LLDP_NEXT_STATUS_CLEANUP_AT )); then
        cleanup_lldp_job_statuses || true
        cleanup_assets_job_statuses || true
        LLDP_NEXT_STATUS_CLEANUP_AT=$((LLDP_NOW + 3600))
    fi
    # Token-specific LLDP jobs keep their own persisted retry/lifecycle state.
    process_lldp_jobs || true
    # Assets uses the same lifecycle contract in a separate request namespace.
    process_assets_jobs || true

    # Check Monitor trigger
    MONITOR_LAST_CHECK=$(read_trigger_timestamp "$MONITOR_LAST_CHECK_FILE")

    if [ -f "$MONITOR_TRIGGER_FILE" ]; then
        if read_monitor_trigger_request "$MONITOR_TRIGGER_FILE"; then
            MONITOR_TRIGGER_TIME=$MONITOR_REQUEST_TOKEN
            MONITOR_TRIGGER_SCOPE=$MONITOR_REQUEST_SCOPE
        else
            MONITOR_TRIGGER_TIME=0
            MONITOR_TRIGGER_SCOPE=all
        fi
        
        if [[ "$MONITOR_TRIGGER_TIME" != "0" && "$MONITOR_TRIGGER_TIME" != "$MONITOR_LAST_CHECK" ]]; then
            if [ "$MONITOR_PENDING_TRIGGER_TIME" != "$MONITOR_TRIGGER_TIME" ]; then
                MONITOR_PENDING_TRIGGER_TIME="$MONITOR_TRIGGER_TIME"
                MONITOR_PENDING_SCOPE="$MONITOR_TRIGGER_SCOPE"
                MONITOR_NEXT_RETRY_AT=0
                MONITOR_RETRY_DELAY="$TRIGGER_RETRY_BASE_SECONDS"
            fi
            MONITOR_NOW=$(date +%s)
            if (( MONITOR_NOW < MONITOR_NEXT_RETRY_AT )); then
                : # Pending; bounded retry window has not elapsed yet
            elif run_under_monitor_lock refresh_monitor \
                    "$MONITOR_PENDING_TRIGGER_TIME" "$MONITOR_PENDING_SCOPE" && \
                 write_trigger_timestamp "$MONITOR_LAST_CHECK_FILE" "$MONITOR_TRIGGER_TIME"; then
                MONITOR_PENDING_TRIGGER_TIME=0
                MONITOR_PENDING_SCOPE=all
                MONITOR_NEXT_RETRY_AT=0
                MONITOR_RETRY_DELAY="$TRIGGER_RETRY_BASE_SECONDS"
            else
                MONITOR_NOW=$(date +%s)
                MONITOR_NEXT_RETRY_AT=$((MONITOR_NOW + MONITOR_RETRY_DELAY))
                printf 'lldpq-trigger: monitor refresh failed; retrying in %ss\n' \
                    "$MONITOR_RETRY_DELAY" >&2
                MONITOR_RETRY_DELAY=$(next_retry_delay \
                    "$MONITOR_RETRY_DELAY" "$TRIGGER_RETRY_MAX_SECONDS")
            fi
        fi
    fi

    # Check Config collection trigger
    CONFIGS_LAST_CHECK=$(read_trigger_timestamp "$CONFIGS_LAST_CHECK_FILE")

    if [ -f "$CONFIGS_TRIGGER_FILE" ]; then
        CONFIGS_TRIGGER_TIME=$(read_trigger_timestamp "$CONFIGS_TRIGGER_FILE")

        if [[ "$CONFIGS_TRIGGER_TIME" != "0" && "$CONFIGS_TRIGGER_TIME" != "$CONFIGS_LAST_CHECK" ]]; then
            if [ "$CONFIGS_PENDING_TRIGGER_TIME" != "$CONFIGS_TRIGGER_TIME" ]; then
                # A new click is attempted immediately even if an older failed
                # request is currently in its retry window.
                CONFIGS_PENDING_TRIGGER_TIME="$CONFIGS_TRIGGER_TIME"
                CONFIGS_NEXT_RETRY_AT=0
                CONFIGS_RETRY_DELAY="$CONFIGS_RETRY_BASE_SECONDS"
            fi
            CONFIGS_NOW=$(date +%s)
            if (( CONFIGS_NOW < CONFIGS_NEXT_RETRY_AT )); then
                : # Pending; bounded retry window has not elapsed yet
            elif [ -f "$CONFIGS_LOCK_FILE" ] && kill -0 "$(cat "$CONFIGS_LOCK_FILE")" 2>/dev/null; then
                : # Config collection already running, skipping trigger
            else
                echo $$ > "$CONFIGS_LOCK_FILE"
                if refresh_configs && \
                   write_trigger_timestamp "$CONFIGS_LAST_CHECK_FILE" "$CONFIGS_TRIGGER_TIME"; then
                    CONFIGS_PENDING_TRIGGER_TIME=0
                    CONFIGS_NEXT_RETRY_AT=0
                    CONFIGS_RETRY_DELAY="$CONFIGS_RETRY_BASE_SECONDS"
                else
                    CONFIGS_NOW=$(date +%s)
                    CONFIGS_NEXT_RETRY_AT=$((CONFIGS_NOW + CONFIGS_RETRY_DELAY))
                    printf 'lldpq-trigger: config refresh failed; retrying in %ss\n' \
                        "$CONFIGS_RETRY_DELAY" >&2
                    CONFIGS_RETRY_DELAY=$(next_retry_delay \
                        "$CONFIGS_RETRY_DELAY" "$CONFIGS_RETRY_MAX_SECONDS")
                fi
                rm -f "$CONFIGS_LOCK_FILE"
            fi
        fi
    fi
    
    # Check Transceiver firmware trigger (on-demand, out-of-band mlxlink sweep)
    TRANSCEIVER_LAST_CHECK=$(read_trigger_timestamp "$TRANSCEIVER_LAST_CHECK_FILE")

    if [ -f "$TRANSCEIVER_TRIGGER_FILE" ]; then
        TRANSCEIVER_TRIGGER_TIME=$(read_trigger_timestamp "$TRANSCEIVER_TRIGGER_FILE")

        if [[ "$TRANSCEIVER_TRIGGER_TIME" != "0" && "$TRANSCEIVER_TRIGGER_TIME" != "$TRANSCEIVER_LAST_CHECK" ]]; then
            # Consume the click immediately; the collector enforces its own lock
            # and minimum interval and runs in the background so it never blocks
            # the other triggers during a potentially minutes-long sweep.
            write_trigger_timestamp "$TRANSCEIVER_LAST_CHECK_FILE" "$TRANSCEIVER_TRIGGER_TIME"
            (
                # This child can outlive the trigger daemon by many minutes.
                # It must not inherit the singleton lock and block a restart.
                exec {DAEMON_LOCK_FD}>&-
                refresh_transceiver
            ) &
        fi
    fi

    # Deterministic one-iteration mode for lifecycle regression tests.  It is
    # intentionally opt-in and does not change the installed daemon loop.
    [[ "${LLDPQ_TRIGGER_RUN_ONCE:-false}" == "true" ]] && break

    # Sleep for 3 seconds before next check
    sleep 3
done
