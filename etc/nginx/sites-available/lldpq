server {
        listen 80 default_server;

        root /var/www/html;

        index index.html index.htm;

        server_name _;

        # Analysis reports and their JSON payloads reach tens of MB at fabric
        # scale, and every response below is no-store; compression is the only
        # transfer-size lever. text/html is always included when gzip is on.
        # octet-stream stays OUT of this list: provisioning serves multi-GB
        # OS images (*.bin/*.img/*.iso, onie-installer aliases) statically and
        # on-the-fly gzip would throttle them and break byte-range resume.
        # The .ini reports are mapped to text/plain below instead.
        gzip on;
        gzip_comp_level 5;
        gzip_min_length 1024;
        gzip_vary on;
        gzip_proxied any;
        gzip_types text/plain text/css text/csv application/json application/javascript text/javascript image/svg+xml;

        location / {
            # Optional: Uncomment lines below to enable authentication
            # auth_basic "LLDPq Network Monitoring";
            # auth_basic_user_file /etc/nginx/.htpasswd;
            
            try_files $uri $uri/ =404;
            add_header Cache-Control "no-store, no-cache, must-revalidate, max-age=0";
            add_header Pragma "no-cache";
            add_header Expires "Thu, 01 Jan 1970 00:00:00 GMT";
        }

        # Every page omitted from the operator menu is also admin-gated when
        # its URL is entered directly. The gateway validates the same session
        # cookie as the APIs before it releases any static HTML bytes.
        location ~ ^/(?:setup|provision|ai|device|console|commands|inventory|vlan-report|vrf-report|fabric-exit|fabric-config|fabric-editor|fabric-deploy|fabric-migration|lldpq-ztp-new-device-flow)\.html$ {
            fastcgi_pass unix:/var/run/fcgiwrap.socket;
            fastcgi_param SCRIPT_FILENAME /var/www/html/admin-page.sh;
            fastcgi_param LLDPQ_ADMIN_PAGE $uri;
            fastcgi_param REQUEST_METHOD $request_method;
            fastcgi_param HTTP_COOKIE $http_cookie;
        }

        # Ask-AI state belongs behind the admin API. Block legacy files that
        # may still exist briefly while an upgraded installation migrates them.
        location ~ ^/ai-(analysis|learnings|analysis-snapshot)\.json$ {
            return 404;
        }

        # Asset inventory contains device addresses, serials and software data.
        # Serve it only through the session-guarded, schema-validating API below.
        location = /assets.ini {
            return 404;
        }
        location = /device-cache.json {
            return 404;
        }
        # Provisioning state is available only through its admin API. The
        # Fabric Deploy cache keeps its existing URL but is session-gated.
        location = /inventory.json {
            return 404;
        }
        location = /discovery-cache.json {
            return 404;
        }
        location = /fabric-scan-cache.json {
            fastcgi_pass unix:/var/run/fcgiwrap.socket;
            fastcgi_param SCRIPT_FILENAME /var/www/html/admin-page.sh;
            fastcgi_param LLDPQ_ADMIN_PAGE $uri;
            fastcgi_param REQUEST_METHOD $request_method;
            fastcgi_param HTTP_COOKIE $http_cookie;
        }
        # Setup editors use same-directory lock, backup and temporary files for
        # atomic replacement. Only the canonical public config names may be read.
        location ~ ^/\.(?:topology\.dot|topology_config\.yaml|display-aliases\.json) {
            return 404;
        }
        location ~ ^/(?:topology\.dot|topology_config\.yaml|display-aliases\.json)\.(?:bak|lock)$ {
            return 404;
        }
        # Same-directory staging is required for atomic rename. Never expose
        # those hidden temporary/rollback files if a process is interrupted.
        location ~ ^/\.(?:assets\.ini|device-cache\.json)\. {
            return 404;
        }
        location /configs/ {
            autoindex on;
            autoindex_exact_size off;
            autoindex_localtime on;
        }
        location /hstr/ {
            autoindex on;
            autoindex_exact_size off;
            autoindex_localtime on;
        }
        location /monitor-results/ {
            autoindex on;
            autoindex_exact_size off;
            autoindex_localtime on;
            add_header Cache-Control "no-store, no-cache, must-revalidate, max-age=0";
            add_header Pragma "no-cache";
            add_header Expires "Thu, 01 Jan 1970 00:00:00 GMT";
        }

        # .ini has no mime.types mapping and would fall back to octet-stream,
        # skipping gzip. The multi-MB text reports (lldp_results.ini, hstr/
        # Problems-*.ini) are monitoring data: text/plain, compressed, never
        # cached. Exact-match guards above (e.g. /assets.ini) still win.
        location ~* \.ini$ {
            default_type text/plain;
            add_header Cache-Control "no-store, no-cache, must-revalidate, max-age=0";
            add_header Pragma "no-cache";
            add_header Expires "Thu, 01 Jan 1970 00:00:00 GMT";
        }

        # ZTP scripts must be served as static files for ONIE/Cumulus.
        location = /cumulus-ztp.sh {
            default_type text/plain;
            try_files /cumulus-ztp.sh =404;
        }

        # Do not expose CGI shell source files as static downloads.
        # Exact fcgiwrap locations below still take precedence.
        location ~ \.sh$ {
            return 404;
        }

        # Never serve backend Python sources (e.g. console-pty.py) as static text.
        location ~ \.py$ {
            return 404;
        }

        # Console — interactive SSH terminal. WebSocket reverse-proxy to the
        # console-pty bridge (admin session is validated inside the bridge).
        location /console-ws {
            proxy_pass http://127.0.0.1:8765;
            proxy_http_version 1.1;
            proxy_set_header Upgrade $http_upgrade;
            proxy_set_header Connection "upgrade";
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header Cookie $http_cookie;
            proxy_read_timeout 86400s;
            proxy_send_timeout 86400s;
            proxy_buffering off;
        }
        
        # Auto-trigger endpoint with fcgiwrap
        location = /trigger-lldp {
            # Execute trigger script via fcgiwrap
            fastcgi_pass unix:/var/run/fcgiwrap.socket;
            fastcgi_param SCRIPT_FILENAME /var/www/html/trigger-lldp.sh;
            fastcgi_param QUERY_STRING $query_string;
            fastcgi_param REQUEST_METHOD $request_method;
            fastcgi_param CONTENT_TYPE $content_type;
            fastcgi_param CONTENT_LENGTH $content_length;
            fastcgi_param HTTP_COOKIE $http_cookie;
        }
        
        # Monitor trigger endpoint with fcgiwrap
        location = /trigger-monitor {
            # Execute trigger script via fcgiwrap
            fastcgi_pass unix:/var/run/fcgiwrap.socket;
            fastcgi_param SCRIPT_FILENAME /var/www/html/trigger-monitor.sh;
            fastcgi_param QUERY_STRING $query_string;
            fastcgi_param REQUEST_METHOD $request_method;
            fastcgi_param CONTENT_TYPE $content_type;
            fastcgi_param CONTENT_LENGTH $content_length;
            fastcgi_param HTTP_COOKIE $http_cookie;
        }
        
        # Assets trigger endpoint with fcgiwrap
        location = /trigger-assets {
            # Execute trigger script via fcgiwrap
            fastcgi_pass unix:/var/run/fcgiwrap.socket;
            fastcgi_param SCRIPT_FILENAME /var/www/html/trigger-assets.sh;
            fastcgi_param QUERY_STRING $query_string;
            fastcgi_param REQUEST_METHOD $request_method;
            fastcgi_param CONTENT_TYPE $content_type;
            fastcgi_param CONTENT_LENGTH $content_length;
            fastcgi_param HTTP_COOKIE $http_cookie;
        }

        # Authenticated, freshness-checked Assets snapshot endpoint.
        location = /assets-api {
            fastcgi_pass unix:/var/run/fcgiwrap.socket;
            fastcgi_param SCRIPT_FILENAME /var/www/html/assets-api.sh;
            fastcgi_param QUERY_STRING $query_string;
            fastcgi_param REQUEST_METHOD $request_method;
            fastcgi_param CONTENT_TYPE $content_type;
            fastcgi_param CONTENT_LENGTH $content_length;
            fastcgi_param HTTP_COOKIE $http_cookie;
        }
        
        # Transceiver firmware trigger endpoint with fcgiwrap
        location = /trigger-transceiver {
            fastcgi_pass unix:/var/run/fcgiwrap.socket;
            fastcgi_param SCRIPT_FILENAME /var/www/html/trigger-transceiver.sh;
            fastcgi_param QUERY_STRING $query_string;
            fastcgi_param REQUEST_METHOD $request_method;
            fastcgi_param CONTENT_TYPE $content_type;
            fastcgi_param CONTENT_LENGTH $content_length;
            fastcgi_param HTTP_COOKIE $http_cookie;
        }
        
        # Config collection trigger endpoint with fcgiwrap
        location = /trigger-configs {
            fastcgi_pass unix:/var/run/fcgiwrap.socket;
            fastcgi_param SCRIPT_FILENAME /var/www/html/trigger-configs.sh;
            fastcgi_param QUERY_STRING $query_string;
            fastcgi_param REQUEST_METHOD $request_method;
            fastcgi_param CONTENT_TYPE $content_type;
            fastcgi_param CONTENT_LENGTH $content_length;
            fastcgi_param HTTP_COOKIE $http_cookie;
        }
        
        # Edit topology.dot endpoint with fcgiwrap
        location = /edit-topology {
            # Execute edit script via fcgiwrap
            fastcgi_pass unix:/var/run/fcgiwrap.socket;
            fastcgi_param SCRIPT_FILENAME /var/www/html/edit-topology.sh;
            fastcgi_param QUERY_STRING $query_string;
            fastcgi_param REQUEST_METHOD $request_method;
            fastcgi_param CONTENT_TYPE $content_type;
            fastcgi_param CONTENT_LENGTH $content_length;
            fastcgi_param HTTP_COOKIE $http_cookie;
        }
        
        # Edit topology_config.yaml endpoint with fcgiwrap
        location = /edit-config {
            # Execute edit script via fcgiwrap
            fastcgi_pass unix:/var/run/fcgiwrap.socket;
            fastcgi_param SCRIPT_FILENAME /var/www/html/edit-config.sh;
            fastcgi_param QUERY_STRING $query_string;
            fastcgi_param REQUEST_METHOD $request_method;
            fastcgi_param CONTENT_TYPE $content_type;
            fastcgi_param CONTENT_LENGTH $content_length;
            fastcgi_param HTTP_COOKIE $http_cookie;

            # Longer timeout: validate can run nv-validate over many configs
            fastcgi_read_timeout 300;
        }
        
        # Edit devices.yaml endpoint with fcgiwrap
        location = /edit-devices {
            # Execute edit script via fcgiwrap
            fastcgi_pass unix:/var/run/fcgiwrap.socket;
            fastcgi_param SCRIPT_FILENAME /var/www/html/edit-devices.sh;
            fastcgi_param QUERY_STRING $query_string;
            fastcgi_param REQUEST_METHOD $request_method;
            fastcgi_param CONTENT_TYPE $content_type;
            fastcgi_param CONTENT_LENGTH $content_length;
            fastcgi_param HTTP_COOKIE $http_cookie;
        }
        
        # Ansible API endpoint with fcgiwrap
        location = /ansible-api {
            # Execute ansible API script via fcgiwrap
            fastcgi_pass unix:/var/run/fcgiwrap.socket;
            fastcgi_param SCRIPT_FILENAME /var/www/html/ansible-api.sh;
            fastcgi_param QUERY_STRING $query_string;
            fastcgi_param REQUEST_METHOD $request_method;
            fastcgi_param CONTENT_TYPE $content_type;
            fastcgi_param CONTENT_LENGTH $content_length;
            fastcgi_param HTTP_COOKIE $http_cookie;
            
            # Longer timeout for ansible operations
            fastcgi_read_timeout 300;
        }
        
        # Authentication API endpoint with fcgiwrap
        location = /auth-api {
            fastcgi_pass unix:/var/run/fcgiwrap.socket;
            fastcgi_param SCRIPT_FILENAME /var/www/html/auth-api.sh;
            fastcgi_param QUERY_STRING $query_string;
            fastcgi_param REQUEST_METHOD $request_method;
            fastcgi_param CONTENT_TYPE $content_type;
            fastcgi_param CONTENT_LENGTH $content_length;
            fastcgi_param HTTP_COOKIE $http_cookie;
        }
        
        # Ansible API endpoint with .sh extension (alias for compatibility)
        location = /ansible-api.sh {
            fastcgi_pass unix:/var/run/fcgiwrap.socket;
            fastcgi_param SCRIPT_FILENAME /var/www/html/ansible-api.sh;
            fastcgi_param QUERY_STRING $query_string;
            fastcgi_param REQUEST_METHOD $request_method;
            fastcgi_param CONTENT_TYPE $content_type;
            fastcgi_param CONTENT_LENGTH $content_length;
            fastcgi_param HTTP_COOKIE $http_cookie;
            fastcgi_read_timeout 300;
        }
        
        # Fabric Configuration API endpoint with fcgiwrap
        location = /fabric-api.sh {
            fastcgi_pass unix:/var/run/fcgiwrap.socket;
            fastcgi_param SCRIPT_FILENAME /var/www/html/fabric-api.sh;
            fastcgi_param QUERY_STRING $query_string;
            fastcgi_param REQUEST_METHOD $request_method;
            fastcgi_param CONTENT_TYPE $content_type;
            fastcgi_param CONTENT_LENGTH $content_length;
            fastcgi_param HTTP_COOKIE $http_cookie;
            
            # Longer timeout for parsing large configs
            fastcgi_read_timeout 60;
        }
        
        # Search API endpoint (MAC/ARP tables)
        location = /search-api.sh {
            fastcgi_pass unix:/var/run/fcgiwrap.socket;
            fastcgi_param SCRIPT_FILENAME /var/www/html/search-api.sh;
            fastcgi_param QUERY_STRING $query_string;
            fastcgi_param REQUEST_METHOD $request_method;
            fastcgi_param CONTENT_TYPE $content_type;
            fastcgi_param CONTENT_LENGTH $content_length;
            fastcgi_param HTTP_COOKIE $http_cookie;
            
            # Longer timeout for parallel device queries
            fastcgi_read_timeout 120;
        }
        
        # SSH Setup API endpoint (send-key + sudo-fix + offline source-tarball upload)
        location = /setup-api.sh {
            fastcgi_pass unix:/var/run/fcgiwrap.socket;
            fastcgi_param SCRIPT_FILENAME /var/www/html/setup-api.sh;
            fastcgi_param QUERY_STRING $query_string;
            fastcgi_param REQUEST_METHOD $request_method;
            fastcgi_param CONTENT_TYPE $content_type;
            fastcgi_param CONTENT_LENGTH $content_length;
            fastcgi_param HTTP_COOKIE $http_cookie;
            
            # Longer timeout for parallel SSH operations across all devices
            fastcgi_read_timeout 300;
            # Allow uploading the source tarball for offline updates (Setup → Update → Offline)
            client_max_body_size 512m;
        }
        
        # AI Assistant API endpoint (LLM proxy + fabric context)
        location = /ai-api.sh {
            fastcgi_pass unix:/var/run/fcgiwrap.socket;
            fastcgi_param SCRIPT_FILENAME /var/www/html/ai-api.sh;
            fastcgi_param QUERY_STRING $query_string;
            fastcgi_param REQUEST_METHOD $request_method;
            fastcgi_param CONTENT_TYPE $content_type;
            fastcgi_param CONTENT_LENGTH $content_length;
            fastcgi_param HTTP_COOKIE $http_cookie;
            
            # Long timeout for LLM responses (streaming can take 60s+)
            fastcgi_read_timeout 300;
            # Disable buffering for SSE streaming
            fastcgi_buffering off;
        }
        
        # Provision API endpoint (ZTP + Base Config)
        location = /provision-api.sh {
            fastcgi_pass unix:/var/run/fcgiwrap.socket;
            fastcgi_param SCRIPT_FILENAME /var/www/html/provision-api.sh;
            fastcgi_param QUERY_STRING $query_string;
            fastcgi_param REQUEST_METHOD $request_method;
            fastcgi_param CONTENT_TYPE $content_type;
            fastcgi_param CONTENT_LENGTH $content_length;
            fastcgi_param HTTP_COOKIE $http_cookie;
            
            # Longer timeout for parallel SCP/SSH deploy operations
            fastcgi_read_timeout 180;
            # Allow large OS image uploads (up to 2GB)
            client_max_body_size 2048m;
        }

        # Inventory / Bootstrap API endpoint (P2P + IPAM design upload + artifact generation)
        location = /inventory-api.sh {
            fastcgi_pass unix:/var/run/fcgiwrap.socket;
            fastcgi_param SCRIPT_FILENAME /var/www/html/inventory-api.sh;
            fastcgi_param QUERY_STRING $query_string;
            fastcgi_param REQUEST_METHOD $request_method;
            fastcgi_param CONTENT_TYPE $content_type;
            fastcgi_param CONTENT_LENGTH $content_length;
            fastcgi_param HTTP_COOKIE $http_cookie;

            # Timeout for xlsx parsing + artifact generation
            fastcgi_read_timeout 120;
            # Allow uploading design workbooks (xlsx/xlsm)
            client_max_body_size 128m;
        }

        # Authenticated read-only switch lifecycle/tracking endpoint
        location = /tracking-api.sh {
            fastcgi_pass unix:/var/run/fcgiwrap.socket;
            fastcgi_param SCRIPT_FILENAME /var/www/html/tracking-api.sh;
            fastcgi_param QUERY_STRING $query_string;
            fastcgi_param REQUEST_METHOD $request_method;
            fastcgi_param CONTENT_TYPE $content_type;
            fastcgi_param CONTENT_LENGTH $content_length;
            fastcgi_param HTTP_COOKIE $http_cookie;
        }

        # ── Public machine-readable exports ─────────────────────────────
        # DELIBERATELY UNAUTHENTICATED (external automation: curl | jq).
        # The monitor-domain exports are static files written inside the
        # monitor publish transaction; index/LLDP/AI render via fcgiwrap.
        # A missing static export (pre-first-run) returns the nginx 404;
        # /export_json reports it as "available": false.

        # Export discovery index
        location = /export_json {
            fastcgi_pass unix:/var/run/fcgiwrap.socket;
            fastcgi_param SCRIPT_FILENAME /var/www/html/export-api.sh;
            fastcgi_param QUERY_STRING $query_string;
            fastcgi_param REQUEST_METHOD $request_method;
        }

        # LLDP wiring results (exact URLs requested by external consumers)
        location = /lldp_results/export_json {
            fastcgi_pass unix:/var/run/fcgiwrap.socket;
            fastcgi_param SCRIPT_FILENAME /var/www/html/lldp-export-api.sh;
            fastcgi_param LLDPQ_EXPORT_FORMAT json;
            fastcgi_param QUERY_STRING $query_string;
            fastcgi_param REQUEST_METHOD $request_method;
        }
        location = /lldp_results/export_csv {
            fastcgi_pass unix:/var/run/fcgiwrap.socket;
            fastcgi_param SCRIPT_FILENAME /var/www/html/lldp-export-api.sh;
            fastcgi_param LLDPQ_EXPORT_FORMAT csv;
            fastcgi_param QUERY_STRING $query_string;
            fastcgi_param REQUEST_METHOD $request_method;
        }

        # Latest AI analysis (JSON passthrough of the AI state file)
        location = /ai/export_json {
            fastcgi_pass unix:/var/run/fcgiwrap.socket;
            fastcgi_param SCRIPT_FILENAME /var/www/html/ai-export-api.sh;
            fastcgi_param QUERY_STRING $query_string;
            fastcgi_param REQUEST_METHOD $request_method;
        }

        # Monitor-domain exports (static, published atomically by monitor.sh)
        # Bare default_type + the charset directive (not a parameterized
        # "type; charset=..." string): gzip_types matches the content type
        # string exactly, so an embedded charset would silently disable
        # compression for these fabric-scale exports.
        location ~ ^/(?<lldpq_export_domain>bgp|evpn-mh|duplicate|flap|optical|ber|pfc-ecn|hardware|log)/export_json$ {
            alias /var/www/html/monitor-results/export/$lldpq_export_domain.json;
            types { }
            default_type application/json;
            charset utf-8;
            charset_types application/json;
            add_header Cache-Control "no-store, no-cache, must-revalidate, max-age=0" always;
        }
        location ~ ^/(?<lldpq_export_domain>bgp|evpn-mh|duplicate|flap|optical|ber|pfc-ecn|hardware|log)/export_csv$ {
            alias /var/www/html/monitor-results/export/$lldpq_export_domain.csv;
            types { }
            default_type text/csv;
            charset utf-8;
            charset_types text/csv;
            add_header Cache-Control "no-store, no-cache, must-revalidate, max-age=0" always;
            add_header Content-Disposition 'attachment; filename="lldpq_${lldpq_export_domain}_export.csv"';
        }

        # Transceiver inventory export (published by collect-transceiver-fw.sh)
        location = /transceiver/export_json {
            alias /var/www/html/monitor-results/transceiver-export.json;
            types { }
            default_type application/json;
            charset utf-8;
            charset_types application/json;
            add_header Cache-Control "no-store, no-cache, must-revalidate, max-age=0" always;
        }
        location = /transceiver/export_csv {
            alias /var/www/html/monitor-results/transceiver-export.csv;
            types { }
            default_type text/csv;
            charset utf-8;
            charset_types text/csv;
            add_header Cache-Control "no-store, no-cache, must-revalidate, max-age=0" always;
            add_header Content-Disposition 'attachment; filename="lldpq_transceiver_export.csv"';
        }
}
